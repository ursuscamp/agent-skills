#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SOURCE_ROOT="$SCRIPT_DIR/skills"
SOURCE_SKILLS="$SOURCE_ROOT"

AGENTS_HOME_DIR="${AGENTS_HOME:-$HOME/.agents}"
DEFAULT_TARGET_ROOT="${AGENTS_SKILLS_DIR:-$AGENTS_HOME_DIR/skills}"
KIRO_TARGET_ROOT="$HOME/.kiro/skills"
TARGET_ROOT="$DEFAULT_TARGET_ROOT"
TARGET_SKILLS="$TARGET_ROOT"
STATE_DIR="$TARGET_ROOT/.skill-sync"
SKILLS_STATE="$STATE_DIR/skills.txt"

MODE="watch"
INSTALL_TARGET="agents"

usage() {
  cat <<'EOF'
Usage: ./install-skills [--watch|--once] [--kiro]

Copies this repo's skills into a shared agent skills directory.

Options:
  --watch  Sync once, then keep watching for changes (default)
  --once   Sync once and exit
  --kiro   Sync to ~/.kiro/skills instead of the default agents target
  --help   Show this help text

Environment:
  AGENTS_HOME       Override the default shared agents directory of ~/.agents
  AGENTS_SKILLS_DIR Override the final skills target directory
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --watch)
      MODE="watch"
      ;;
    --once)
      MODE="once"
      ;;
    --kiro)
      INSTALL_TARGET="kiro"
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown argument: %s\n\n' "$1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

if [ "$INSTALL_TARGET" = "kiro" ]; then
  TARGET_ROOT="$KIRO_TARGET_ROOT"
  TARGET_SKILLS="$TARGET_ROOT"
  STATE_DIR="$TARGET_ROOT/.skill-sync"
  SKILLS_STATE="$STATE_DIR/skills.txt"
fi

require_source_layout() {
  if [ ! -d "$SOURCE_SKILLS" ]; then
    printf 'Missing source skills directory: %s\n' "$SOURCE_SKILLS" >&2
    exit 1
  fi
}

prepare_target_dirs() {
  mkdir -p "$TARGET_SKILLS" "$STATE_DIR"
}

sync_skills() {
  local current_file
  current_file="$(mktemp)"

  while IFS= read -r source_dir; do
    local name
    name="$(basename "$source_dir")"
    printf '%s\n' "$name" >> "$current_file"
    mkdir -p "$TARGET_SKILLS/$name"
    rsync -a --delete "$source_dir/" "$TARGET_SKILLS/$name/"
  done < <(python3 - <<'PY' "$SOURCE_SKILLS"
import pathlib
import sys

source_skills = pathlib.Path(sys.argv[1])
for path in sorted(source_skills.iterdir()):
    if path.is_dir() and (path / "SKILL.md").is_file():
        print(path)
PY
)

  if [ -f "$SKILLS_STATE" ]; then
    while IFS= read -r entry; do
      [ -n "$entry" ] || continue

      if grep -Fqx "$entry" "$current_file"; then
        continue
      fi

      rm -rf "$TARGET_SKILLS/$entry"
    done < "$SKILLS_STATE"
  fi

  mv "$current_file" "$SKILLS_STATE"
}

sync_all() {
  sync_skills
  printf '[%s] Synced to %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$TARGET_ROOT"
}

watch_with_fswatch() {
  fswatch -o "$SOURCE_SKILLS" | while IFS= read -r _; do
    sync_all
  done
}

watch_with_python() {
  python3 - <<'PY' "$SOURCE_SKILLS" | while IFS= read -r _; do
import hashlib
import os
import pathlib
import sys
import time

roots = [pathlib.Path(arg) for arg in sys.argv[1:]]

def snapshot():
    entries = []
    for root in roots:
        if not root.exists():
            continue
        for dirpath, dirnames, filenames in os.walk(root):
            dirnames[:] = sorted(d for d in dirnames if not d.startswith('.'))
            for name in sorted(f for f in filenames if not f.startswith('.')):
                path = pathlib.Path(dirpath, name)
                stat = path.stat()
                entries.append((str(path), stat.st_mtime_ns, stat.st_size))
    return hashlib.sha256(repr(entries).encode()).hexdigest()

previous = snapshot()
while True:
    time.sleep(1)
    current = snapshot()
    if current != previous:
        previous = current
        print("changed", flush=True)
PY
    sync_all
  done
}

main() {
  require_source_layout
  prepare_target_dirs
  sync_all

  if [ "$MODE" = "once" ]; then
    exit 0
  fi

  printf 'Watching %s for changes... Press Ctrl+C to stop.\n' "$SOURCE_ROOT"

  if command -v fswatch >/dev/null 2>&1; then
    watch_with_fswatch
  else
    watch_with_python
  fi
}

main
